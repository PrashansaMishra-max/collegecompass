generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  savedColleges SavedCollege[]
  questions     Question[]
  answers       Answer[]
  reviews       Review[]
  accounts      Account[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model College {
  id           String   @id @default(cuid())
  name         String
  location     String
  state        String
  fees         Int
  rating       Float
  overview     String
  placements   String
  image        String?
  type         String
  courses      String[]
  createdAt    DateTime @default(now())
  savedBy      SavedCollege[]
  questions    Question[]
  reviews      Review[]
}

model SavedCollege {
  id        String  @id @default(cuid())
  userId    String
  collegeId String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  college   College @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
}

model Question {
  id        String   @id @default(cuid())
  body      String
  userId    String
  collegeId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  answers   Answer[]
}

model Answer {
  id         String   @id @default(cuid())
  body       String
  userId     String
  questionId String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  body      String
  rating    Float
  userId    String
  collegeId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}